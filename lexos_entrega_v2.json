{
  "openapi": "3.0.1",
  "info": {
    "title": "Entrega",
    "description": "Conjunto de APIs para manipulação de entregas",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.lexos.com.br/Entrega"
    }
  ],
  "tags": [
    {
      "name": "Entrega",
      "description": "Operações relacionadas a entregas"
    }
  ],
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "name": "Ocp-Apim-Subscription-Key",
        "in": "header"
      },
      "apiKeyQuery": {
        "type": "apiKey",
        "in": "header",
        "name": "subscription-key"
      }
    },
    "schemas": {
      "Entrega": {
        "type": "object",
        "properties": {
          "EntregaId": {
            "type": "integer"
          },
          "PedidoId": {
            "type": "integer"
          },
          "AtualizadoEm": {
            "type": "string",
            "format": "date-time"
          },
          "EntregaStatus": {
            "type": "string"
          },
          "PedidoStatus": {
            "type": "string"
          }
        }
      },
      "ListaEntregasResponse": {
        "type": "object",
        "properties": {
          "PaginaAtual": {
            "type": "integer"
          },
          "TotalPaginas": {
            "type": "integer"
          },
          "TotalRegistros": {
            "type": "integer"
          },
          "Entregas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Entrega"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": [],
      "apiKeyQuery": []
    }
  ],
  "paths": {
    "/ObterLista": {
      "get": {
        "tags": [
          "Entrega"
        ],
        "summary": "Lista entregas",
        "operationId": "listarEntregas",
        "parameters": [
          {
            "name": "Pagina",
            "in": "query",
            "description": "Índice da página",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "AtualizadoEm",
            "in": "query",
            "description": "Filtro por data de atualização (YYYY-MM-DD HH:mm)",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "Status",
            "in": "query",
            "description": "Status da entrega (separados por vírgula)",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de entregas retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListaEntregasResponse"
                }
              }
            }
          },
          "400": {
            "description": "Erro de validação"
          },
          "404": {
            "description": "Nenhuma entrega encontrada"
          }
        }
      }
    },
    "/PrepararEnvio": {
      "post": {
        "tags": [
          "Entrega"
        ],
        "summary": "Prepara envio de um pedido",
        "operationId": "prepararEnvio",
        "parameters": [
          {
            "name": "PedidoId",
            "in": "query",
            "required": true,
            "description": "ID do pedido",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido preparado com sucesso"
          },
          "400": {
            "description": "Erro de validação"
          },
          "404": {
            "description": "Pedido não encontrado"
          }
        }
      }
    },
    "/PrepararEnvioBatch": {
      "post": {
        "tags": [
          "Entrega"
        ],
        "summary": "Prepara envio em lote",
        "operationId": "prepararEnvioBatch",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              },
              "example": [
                9442134,
                126653,
                4555216
              ]
            }
          }
        },
        "responses": {
          "202": {
            "description": "Processo agendado com sucesso"
          },
          "400": {
            "description": "Erro de validação"
          }
        }
      }
    }
  }
}