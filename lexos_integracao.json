{
  "openapi": "3.0.1",
  "info": {
    "title": "Integracao",
    "description": "Conjunto de APIs para manipulação de integrações",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://api.lexos.com.br/integracao"
    }
  ],
  "paths": {
    "/Instalar": {
      "post": {
        "tags": ["Integracao"],
        "summary": "Instalar integração",
        "description": "FLUXO: LEXOS PLATAFORMA",
        "operationId": "instalarIntegracao",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT Bearer Token obtido no processo de autenticação",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Chave",
            "in": "header",
            "description": "Chave da integração no LexosHub",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Lexos-Hmac-SHA256",
            "in": "header",
            "description": "Hash para garantir autenticidade da requisição",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InstalarRequest"
              },
              "example": {
                "id": "string",
                "webhookUrl": "https://meusistema.com/webhook"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Integração instalada com sucesso"
          },
          "400": {
            "description": "Erro de validação"
          },
          "500": {
            "description": "Erro interno"
          }
        }
      }
    },
    "/ObterLista": {
      "get": {
        "tags": ["Integracao"],
        "summary": "Obter lista de integrações",
        "description": "Retorna as integrações ativas",
        "operationId": "obterListaIntegracoes",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT Bearer Token obtido no processo de autenticação",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Chave",
            "in": "header",
            "description": "Chave da integração no LexosHub",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de integrações retornada com sucesso"
          },
          "400": {
            "description": "Erro de validação"
          },
          "500": {
            "description": "Erro interno"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "InstalarRequest": {
        "type": "object",
        "required": ["id", "webhookUrl"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Identificador da integração"
          },
          "webhookUrl": {
            "type": "string",
            "description": "URL para recebimento de eventos"
          }
        }
      }
    },
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "name": "Ocp-Apim-Subscription-Key",
        "in": "header"
      },
      "apiKeyQuery": {
        "type": "apiKey",
        "name": "subscription-key",
        "in": "query"
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    },
    {
      "apiKeyQuery": []
    }
  ]
}