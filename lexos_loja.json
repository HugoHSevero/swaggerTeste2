{
  "openapi": "3.0.1",
  "info": {
    "title": "Loja",
    "description": "Conjunto de APIs para manipulação das lojas",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://api.lexos.com.br/loja"
    }
  ],
  "paths": {
    "/ObterLista": {
      "get": {
        "tags": ["Loja"],
        "summary": "ObterLista",
        "operationId": "obterListaLojas",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Chave",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de lojas retornada com sucesso"
          },
          "400": {
            "description": "Erro de validação"
          },
          "404": {
            "description": "Nenhuma loja encontrada"
          }
        }
      }
    }
  }
}