{
  "openapi": "3.0.1",
  "info": {
    "title": "Pedido",
    "description": "Conjunto de APIs para manipulação de pedidos",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://api.lexos.com.br/Pedido"
    }
  ],
  "tags": [
    { "name": "Pedido" }
  ],
  "paths": {

    "/ObterPorId": {
      "get": {
        "tags": ["Pedido"],
        "summary": "Obter pedido por ID",
        "operationId": "obterPorId",
        "parameters": [
          { "name": "PedidoId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Sucesso" },
          "400": { "description": "Erro de validação" },
          "404": { "description": "Não encontrado" }
        }
      }
    },

    "/AtualizarPedidoErpId": {
      "put": {
        "tags": ["Pedido"],
        "summary": "Atualizar ERP ID",
        "operationId": "atualizarPedidoErpId",
        "parameters": [
          { "name": "PedidoId", "in": "query", "required": true, "schema": { "type": "integer", "format": "int64" } },
          { "name": "PedidoErpId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Atualizado" },
          "400": { "description": "Erro" }
        }
      }
    },

    "/TrocaDeLojaPorId/{PedidoTrocaLojaId}": {
      "get": {
        "tags": ["Pedido"],
        "summary": "Troca de loja",
        "operationId": "trocaDeLoja",
        "parameters": [
          { "name": "PedidoTrocaLojaId", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Sucesso" }
        }
      }
    },

    "/ObterLista": {
      "get": {
        "tags": ["Pedido"],
        "summary": "Listar pedidos",
        "operationId": "obterLista",
        "parameters": [
          { "name": "Pagina", "in": "query", "schema": { "type": "integer" } },
          { "name": "Data", "in": "query", "schema": { "type": "string" } },
          { "name": "AtualizadoEm", "in": "query", "schema": { "type": "string" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Lista retornada" }
        }
      }
    },

    "/ObterEtiqueta": {
      "get": {
        "tags": ["Pedido"],
        "summary": "Obter etiqueta",
        "operationId": "obterEtiqueta",
        "parameters": [
          { "name": "PedidoId", "in": "query", "schema": { "type": "integer" } },
          { "name": "Codigo", "in": "query", "schema": { "type": "string" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Etiqueta em Base64" }
        }
      }
    },

    "/ObterNotaFiscal": {
      "get": {
        "tags": ["Pedido"],
        "summary": "Obter nota fiscal",
        "operationId": "obterNotaFiscal",
        "parameters": [
          { "name": "PedidoId", "in": "query", "required": true, "schema": { "type": "integer" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Nota fiscal retornada" }
        }
      }
    },

    "/PrepararEnvio": {
      "post": {
        "tags": ["Pedido"],
        "summary": "Preparar envio",
        "operationId": "prepararEnvio",
        "parameters": [
          { "name": "PedidoId", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Preparado" }
        }
      }
    },

    "/PrepararEnvioBatch": {
      "post": {
        "tags": ["Pedido"],
        "summary": "Preparar envio em lote",
        "operationId": "prepararEnvioBatch",
        "parameters": [
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "type": "integer" }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Processamento iniciado" }
        }
      }
    },

    "/Incluir": {
      "post": {
        "tags": ["Pedido"],
        "summary": "Incluir pedido",
        "operationId": "incluirPedido",
        "parameters": [
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" } },
          { "name": "Chave", "in": "header", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IncluirPedidoModel"
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Pedido recebido" }
        }
      }
    }

  },

  "components": {
    "schemas": {
      "IncluirPedidoModel": {
        "type": "object",
        "properties": {
          "codigo": { "type": "string" },
          "codigoPlataforma": { "type": "string" },
          "total": { "type": "number" }
        }
      }
    }
  }
}